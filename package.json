{
  "name": "bugspotter",
  "version": "0.1.0",
  "description": "Intelligent bug reporting platform with one-click context capture",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter \"./packages/*\" dev",
    "build": "pnpm --filter \"./packages/*\" build",
    "test": "pnpm --filter \"./packages/*\" test",
    "format": "prettier --write \"**/*.{js,ts,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md,html,css}\"",
    "lint": "eslint \"packages/*/src/**/*.{ts,js}\" \"apps/*/src/**/*.{ts,tsx,js}\" \"apps/*/tests/**/*.{mjs,ts,js}\"",
    "lint:fix": "eslint \"packages/*/src/**/*.{ts,js}\" \"apps/*/src/**/*.{ts,tsx,js}\" \"apps/*/tests/**/*.{mjs,ts,js}\" --fix",
    "prepare": "husky || true",
    "validate:i18n": "node scripts/validate-i18n.mjs",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:api": "docker-compose logs -f api",
    "docker:logs:worker": "docker-compose logs -f worker",
    "docker:restart": "docker-compose restart",
    "docker:ps": "docker-compose ps",
    "docker:clean": "docker-compose down -v",
    "docker:test": "docker-compose exec api pnpm test"
  },
  "keywords": [
    "bug-tracking",
    "qa",
    "testing"
  ],
  "author": "",
  "license": "FSL-1.1-Apache-2.0",
  "pnpm": {
    "overrides": {
      "tar": "^7.4.0",
      "fast-jwt": "^6.2.4",
      "jws": "^3.2.3",
      "pino": "^9.13.1"
    }
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20.17"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/admin/src/i18n/locales/*.json": [
      "prettier --write",
      "pnpm validate:i18n"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.19.1"
  },
  "dependencies": {
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "browser-sync": "^3.0.4",
    "isolated-vm": "^6.0.2"
  }
}
