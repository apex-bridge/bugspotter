# ===================================
# Integration Test Environment Variables
# ===================================
# 
# These variables are used for integration testing notification delivery
# with real external services. Copy to .env.integration and fill in with
# test credentials.
#
# Usage: RUN_INTEGRATION_TESTS=true pnpm test tests/integration/notification-delivery.test.ts

# Enable integration tests (default: false)
RUN_INTEGRATION_TESTS=false

# ===================================
# Email (SMTP) Integration Tests
# ===================================

# Gmail example (requires App Password with 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=bugspotter-test@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM_ADDRESS=bugspotter-test@gmail.com
EMAIL_RECIPIENTS=bugspotter-test@gmail.com  # Comma-separated list of test recipients

# Outlook example
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=bugspotter-test@outlook.com
# SMTP_PASS=your-password

# Custom SMTP server
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=test@example.com
# SMTP_PASS=password

# ===================================
# Slack Integration Tests
# ===================================

# Create a Slack App with Incoming Webhooks:
# 1. Go to https://api.slack.com/apps
# 2. Create new app or select existing
# 3. Enable Incoming Webhooks
# 4. Add webhook to workspace
# 5. Copy webhook URL

SLACK_TEST_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX
SLACK_TEST_CHANNEL=#bugspotter-test  # Optional: override default channel

# Optional: For E2E test verification (read messages to confirm delivery)
# Create a bot token with channels:history scope
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_TEST_CHANNEL_ID=C00000000  # Channel ID (not name) for verification

# ===================================
# Discord Integration Tests
# ===================================

# Create a Discord webhook:
# 1. Go to your Discord server
# 2. Server Settings → Integrations → Webhooks
# 3. Create New Webhook
# 4. Choose channel and copy webhook URL

DISCORD_TEST_WEBHOOK_URL=https://discord.com/api/webhooks/123456789012345678/abcdefghijklmnopqrstuvwxyz1234567890

# Optional: For E2E test verification (read messages to confirm delivery)
# Create a bot and add to your server with Read Message History permission
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_TEST_CHANNEL_ID=123456789012345678  # Channel ID for verification

# ===================================
# Microsoft Teams Integration Tests
# ===================================

# Create a Teams webhook:
# 1. Go to your Teams channel
# 2. Click ••• → Connectors → Incoming Webhook
# 3. Configure and create
# 4. Copy webhook URL

TEAMS_TEST_WEBHOOK_URL=https://outlook.office.com/webhook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx@xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/IncomingWebhook/yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy/zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz

# ===================================
# Generic Webhook Integration Tests
# ===================================

# Use webhook.site or your own test endpoint:
# 1. Go to https://webhook.site
# 2. Copy your unique URL
# 3. View received requests in real-time

WEBHOOK_TEST_URL=https://webhook.site/your-unique-id

# Or use a local test server:
# WEBHOOK_TEST_URL=http://localhost:3001/webhook-test

# ===================================
# CI/CD Setup
# ===================================
#
# For GitHub Actions, add these as repository secrets:
# - Settings → Secrets and variables → Actions → New repository secret
#
# Example GitHub Actions workflow:
#
# jobs:
#   integration-tests:
#     runs-on: ubuntu-latest
#     steps:
#       - uses: actions/checkout@v3
#       - name: Run integration tests
#         env:
#           RUN_INTEGRATION_TESTS: true
#           SMTP_HOST: ${{ secrets.SMTP_HOST }}
#           SMTP_USER: ${{ secrets.SMTP_USER }}
#           SMTP_PASS: ${{ secrets.SMTP_PASS }}
#           # ... add other secrets
#         run: pnpm test tests/integration/notification-delivery.test.ts

# ===================================
# Security Notes
# ===================================
#
# 1. Never commit this file with real credentials
# 2. Use dedicated test accounts (not production)
# 3. Rotate credentials regularly
# 4. Limit permissions to minimum required
# 5. Use app-specific passwords where available (Gmail, Outlook)
# 6. Monitor test accounts for unauthorized access
# 7. Add .env.integration to .gitignore

# ===================================
# Troubleshooting
# ===================================
#
# Email tests failing?
# - Gmail: Enable 2FA, create App Password (not account password)
# - Outlook: Use account password or app password
# - Check firewall: Ports 587 (TLS) or 465 (SSL) must be open
# - Verify SMTP host: smtp.gmail.com, smtp-mail.outlook.com, etc.
#
# Webhook tests failing?
# - Verify URL is active and accessible
# - Check network connectivity
# - Ensure webhook hasn't expired
# - Discord/Slack: Webhooks can be deleted from their dashboards
#
# Run with debug logging:
# DEBUG=* RUN_INTEGRATION_TESTS=true pnpm test notification-delivery.test.ts
