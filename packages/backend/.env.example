# Database connection
DATABASE_URL=postgresql://username:password@localhost:5432/bugspotter

# Deployment mode: 'selfhosted' (default) or 'saas'
DEPLOYMENT_MODE=selfhosted

# Server configuration
PORT=3000
NODE_ENV=development

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here

# Optional: Database connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=30000
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY_MS=1000

# Optional: API rate limiting (1 minute window, 100 requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration (SECURITY - REQUIRED IN PRODUCTION)
# Comma-separated list of allowed origins
# Development: http://localhost:3000,http://localhost:5173
# Production: https://app.yourdomain.com (set to your actual frontend domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT Token Expiration
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# User self-registration
# Controls whether users can create accounts via POST /api/v1/auth/register
# Default: true when DEPLOYMENT_MODE=saas, false otherwise (self-hosted)
# Set explicitly to override the default for your deployment mode
# ALLOW_REGISTRATION=true

# Invitation-only registration
# When true, users must provide a valid invite_token to register.
# The invitation email must match the registration email.
# Default: true (secure — only invited users can create accounts)
# Set to false for open registration (anyone can sign up)
# REQUIRE_INVITATION_TO_REGISTER=true

# Self-service signup (POST /api/v1/auth/signup)
# Separate from /auth/register — this endpoint provisions an entire
# tenant (user + org + trial + project + API key) in one atomic call.
# Default: true when DEPLOYMENT_MODE=saas, false otherwise.
# SELF_SERVICE_SIGNUP_ENABLED=true

# Cookie domain for refresh_token
# When set, the refresh cookie gets `Domain=<value>` + `SameSite=Lax`
# so a session set on one subdomain (e.g. `api.kz.bugspotter.io`) is
# sent back on every other subdomain (e.g. `acme.kz.bugspotter.io`).
# Required for cross-subdomain SSO between the signup wizard and
# tenant admin UIs. Leave empty for self-hosted / single-host deploys
# — cookies stay host-scoped with `SameSite=Strict`.
#
# Must be a bare hostname (no scheme, path, port, or whitespace).
# Common values: `.kz.bugspotter.io`, `kz.bugspotter.io`, `localhost`.
# Validated at startup — bad values fail boot.
# COOKIE_DOMAIN=.kz.bugspotter.io

# Data residency region for this deployment
# Drives billing currency, data placement, and the value written to
# the `data_residency_region` column on new organizations. Validated
# at startup against the DATA_RESIDENCY_REGION enum
# (see src/db/types.ts). Allowed: kz, rf, eu, us, global.
# Default: kz.
# DATA_RESIDENCY_REGION=kz

# File Upload Limits (in bytes, default 10MB)
MAX_UPLOAD_SIZE=10485760

# Logging Level (debug, info, warn, error)
# Production: warn or error (reduces log volume, better performance)
# Development: debug or info (verbose logging for troubleshooting)
# Default: 'info' in production, 'debug' in development
LOG_LEVEL=info

# ===================================
# Retention Policy Configuration
# ===================================

# Default retention periods (days)
DEFAULT_RETENTION_DAYS=90
SCREENSHOT_RETENTION_DAYS=60
REPLAY_RETENTION_DAYS=30
ATTACHMENT_RETENTION_DAYS=90
ARCHIVED_RETENTION_DAYS=365

# Compliance region: none, eu, us, kz, uk, ca
# Determines regulatory requirements (GDPR, SOX, Kazakhstan law, etc.)
COMPLIANCE_REGION=none

# Retention scheduler (cron format)
RETENTION_CRON_SCHEDULE="0 2 * * *"       # Daily at 2 AM
RETENTION_CRON_TIMEZONE="UTC"             # Timezone for scheduled jobs
RETENTION_SCHEDULER_ENABLED=true

# ===================================
# Frontend Configuration
# ===================================

# Frontend URL for building share links (required in production)
# Used by share token routes to generate public replay URLs
# Development: http://localhost:3000 (default fallback)
# Production: https://admin.bugspotter.com (or your admin panel domain)
FRONTEND_URL=http://localhost:3000

# Share token configuration
SHARE_TOKEN_DEFAULT_EXPIRATION_HOURS=24    # Default: 24 hours (1-720 max)
PRESIGNED_URL_EXPIRATION_SECONDS=3600      # S3/storage URL validity: 1 hour

# ===================================
# Setup Wizard Configuration
# ===================================

# Setup mode: minimal (admin-only, requires env vars) or full (admin + storage UI)
# - minimal: Only creates admin user, storage must be configured via environment variables
#   Best for production deployments where infrastructure is pre-configured
# - full: Complete setup wizard with storage and instance configuration
#   Best for self-hosted/download-and-run deployments
SETUP_MODE=minimal

# Optional: Pre-configure admin account (full mode only, or ADMIN_EMAIL for minimal)
# ADMIN_EMAIL=admin@company.com
# ADMIN_PASSWORD=secure_password_here
# ADMIN_NAME=Admin User

# Optional: Pre-configure instance settings (full mode only)
# INSTANCE_NAME=BugSpotter
# INSTANCE_URL=https://bugspotter.company.com

# ===================================
# Storage Configuration
# ===================================

# Storage backend: local, s3, minio, or r2
STORAGE_BACKEND=local

# Local Storage (for development/testing)
STORAGE_BASE_DIR=./data/uploads
STORAGE_BASE_URL=http://localhost:3000/uploads

# S3-Compatible Storage (AWS S3, MinIO, Cloudflare R2)
# Uncomment and configure when using S3-compatible storage

# S3_ENDPOINT=                    # Optional: for MinIO/R2 (e.g., http://localhost:9000)
# S3_REGION=us-east-1            # AWS region or MinIO region
# S3_ACCESS_KEY=                  # AWS Access Key ID or MinIO access key
# S3_SECRET_KEY=                  # AWS Secret Access Key or MinIO secret key
# S3_BUCKET=bugspotter           # Bucket name
# S3_MAX_RETRIES=3               # Number of retry attempts
# S3_TIMEOUT_MS=30000            # Request timeout in milliseconds

# Example MinIO Configuration:
# STORAGE_BACKEND=minio
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=bugspotter

# Example AWS S3 Configuration:
# STORAGE_BACKEND=s3
# S3_REGION=us-east-1
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_BUCKET=bugspotter-prod

# Example Cloudflare R2 Configuration:
# STORAGE_BACKEND=r2
# S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY=your-r2-access-key
# S3_SECRET_KEY=your-r2-secret-key
# S3_BUCKET=bugspotter

# ===================================
# Encryption (Required for Integrations)
# ===================================

# Encryption key for storing credentials (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-encryption-key-here

# ===================================
# Plugin System Configuration
# ===================================

# Plugin execution timeout (milliseconds)
# How long a custom plugin can run before being terminated
# Must be greater than HTTP fetch timeout (10s) to allow external requests to complete
# Default: 15000 (15 seconds)
PLUGIN_EXECUTION_TIMEOUT_MS=15000

# ===================================
# Jira Integration (Optional)
# ===================================

# Global/Default Jira Configuration (optional - can be configured per-project via API)
# Leave empty to configure per-project through the dashboard/API
# JIRA_HOST=https://yourcompany.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECT_KEY=BUG
# JIRA_ISSUE_TYPE=Bug

# ===================================
# Job Queue Configuration (BullMQ)
# ===================================

# Redis Configuration
# For local development with Docker Compose, use: redis://:yourpassword@localhost:6379
# For managed Redis or production, include password: redis://:password@host:port
REDIS_URL=redis://:changeme@localhost:6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# Worker Configuration (enable/disable specific workers)
WORKER_SCREENSHOT_ENABLED=true
WORKER_REPLAY_ENABLED=true
WORKER_INTEGRATION_ENABLED=true
WORKER_NOTIFICATION_ENABLED=true

# Worker Concurrency (number of parallel jobs)
WORKER_SCREENSHOT_CONCURRENCY=5
WORKER_REPLAY_CONCURRENCY=3
WORKER_INTEGRATION_CONCURRENCY=10
WORKER_NOTIFICATION_CONCURRENCY=5

# Payment event worker (processes webhook events from payment-service)
WORKER_PAYMENT_EVENT_ENABLED=true
WORKER_PAYMENT_EVENT_CONCURRENCY=5

# Intelligence worker (processes bug analysis via intelligence service)
# Requires INTELLIGENCE_ENABLED=true and a running intelligence service
WORKER_INTELLIGENCE_ENABLED=false
WORKER_INTELLIGENCE_CONCURRENCY=3

# ===================================
# Email Notifications (Optional)
# ===================================

# Enable email notifications
EMAIL_NOTIFICATIONS_ENABLED=false

# From address for notification emails
EMAIL_FROM_ADDRESS=noreply@bugspotter.com

# SMTP Configuration (for standard email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Alternative: API-based providers (optional)
# Uncomment and configure if using SendGrid, SES, Postmark, or Resend instead of SMTP
# EMAIL_PROVIDER=sendgrid        # Options: sendgrid, ses, postmark, mailgun
# EMAIL_API_KEY=your-api-key     # Provider API key

# Example: SendGrid Configuration
# EMAIL_NOTIFICATIONS_ENABLED=true
# EMAIL_FROM_ADDRESS=notifications@yourdomain.com
# EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Example: Gmail SMTP Configuration (requires App Password)
# EMAIL_NOTIFICATIONS_ENABLED=true
# EMAIL_FROM_ADDRESS=your-email@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-character-app-password

# Job Configuration
JOB_RETENTION_DAYS=7              # How long to keep completed jobs
MAX_JOB_RETRIES=3                 # Max retry attempts for failed jobs
BACKOFF_DELAY=5000                # Initial backoff delay in ms
JOB_TIMEOUT=300000                # Job timeout in ms (5 minutes)

# Processing Configuration
REPLAY_CHUNK_DURATION=30          # Replay chunk duration in seconds
MAX_REPLAY_SIZE_MB=100            # Max replay size before chunking
THUMBNAIL_WIDTH=320               # Thumbnail width in pixels
THUMBNAIL_HEIGHT=240              # Thumbnail height in pixels
SCREENSHOT_QUALITY=85             # JPEG quality (1-100)

# ===================================
# Intelligence Service (Optional)
# ===================================

# Enable the bugspotter-intelligence RAG integration
INTELLIGENCE_ENABLED=false

# Intelligence service URL
INTELLIGENCE_API_URL=http://localhost:8000

# Intelligence service API key (obtain from intelligence service admin)
# INTELLIGENCE_API_KEY=bsi_your-api-key-here

# HTTP client settings
INTELLIGENCE_TIMEOUT_MS=10000
INTELLIGENCE_MAX_RETRIES=3
INTELLIGENCE_BACKOFF_DELAY_MS=1000

# Circuit breaker settings (protects backend when intelligence is unavailable)
INTELLIGENCE_CB_FAILURE_THRESHOLD=5
INTELLIGENCE_CB_RESET_TIMEOUT_MS=30000
