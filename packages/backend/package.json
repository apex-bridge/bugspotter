{
  "name": "@bugspotter/backend",
  "version": "0.1.0",
  "description": "BugSpotter self-hosted backend with PostgreSQL",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "start": "node dist/api/index.js",
    "worker:dev": "tsx watch src/worker.ts",
    "worker:start": "node dist/worker.js",
    "build": "tsc && node scripts/copy-migrations.mjs",
    "migrate": "tsx src/db/migrations/migrate.ts",
    "migrate:create": "tsx src/db/migrations/create-migration.ts",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:queue": "vitest run tests/integration/queue-integration.test.ts --config vitest.integration.config.ts",
    "test:load": "vitest run --config vitest.load.config.ts",
    "test:notifications": "vitest run tests/integration/*-delivery.test.ts --config vitest.integration.config.ts",
    "test:notifications:email": "vitest run tests/integration/email-delivery.test.ts --config vitest.integration.config.ts",
    "test:notifications:slack": "vitest run tests/integration/slack-delivery.test.ts --config vitest.integration.config.ts",
    "test:notifications:discord": "vitest run tests/integration/discord-delivery.test.ts --config vitest.integration.config.ts",
    "test:notifications:teams": "vitest run tests/integration/teams-delivery.test.ts --config vitest.integration.config.ts",
    "test:notifications:webhook": "vitest run tests/integration/webhook-delivery.test.ts --config vitest.integration.config.ts",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:load",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:integration:watch": "vitest watch --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:cleanup": "bash scripts/cleanup-test-data.sh",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.907.0",
    "@aws-sdk/lib-storage": "^3.907.0",
    "@aws-sdk/s3-request-presigner": "^3.906.0",
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.5",
    "@bugspotter/billing": "workspace:^",
    "@bugspotter/message-broker": "workspace:*",
    "@bugspotter/types": "workspace:*",
    "@bugspotter/utils": "workspace:*",
    "@bull-board/api": "^6.13.0",
    "@bull-board/fastify": "^6.13.0",
    "@bull-board/ui": "^6.13.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.2.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.61.0",
    "cron-parser": "^5.4.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "handlebars": "^4.7.9",
    "ioredis": "^5.8.1",
    "isolated-vm": "^6.0.2",
    "jsonwebtoken": "^9.0.3",
    "md-to-adf": "^0.6.4",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.4",
    "validator": "^13.15.26",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@smithy/types": "^4.9.0",
    "@testcontainers/postgresql": "^11.7.1",
    "@types/babel__traverse": "^7.28.0",
    "@types/bcrypt": "^5.0.2",
    "@types/handlebars": "^4.1.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.20",
    "@types/pg": "^8.11.10",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^3.2.4",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.7.5",
    "node-gyp": "^10.3.1",
    "testcontainers": "^11.7.1",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
