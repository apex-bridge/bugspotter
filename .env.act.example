# Environment variables for act (local GitHub Actions emulation)
# Copy this to .env.act and fill in the values
# DO NOT commit .env.act with real secrets!

# PostgreSQL
POSTGRES_DB=bugspotter
POSTGRES_USER=bugspotter
POSTGRES_PASSWORD=bugspotter_ci_password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=bugspotter

# Security (use random values for local testing)
JWT_SECRET=local_jwt_secret_key_for_act_testing_only_not_production
ENCRYPTION_KEY=local_encryption_key_for_act_testing_only_32bytes

# Environment
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3001

# GitHub Token (optional, for API rate limits)
# Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here
