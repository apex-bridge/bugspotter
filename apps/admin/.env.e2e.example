# Admin E2E Test Environment Variables
# Copy this to .env.e2e and fill in your test credentials

# Base URL for admin panel
BASE_URL=http://localhost:3001

# Integration test flags
RUN_INTEGRATION_TESTS=true

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=your-password
EMAIL_FROM=noreply@bugspotter.io
EMAIL_TEST_RECIPIENT=test@example.com

# Slack Configuration
SLACK_TEST_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_CHANNEL/YOUR_SECRET
SLACK_TEST_CHANNEL=#test-notifications
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Discord Configuration
DISCORD_TEST_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# Microsoft Teams Configuration
TEAMS_TEST_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR_WEBHOOK_URL
